{
  "name": "digital-guestbook",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/kill-dev.js",
    "dev": "node scripts/ensure-local-build.js && set NEXT_TELEMETRY_DISABLED=1&& next dev -p 3000",
    "build": "node scripts/ensure-local-build.js && set NEXT_TELEMETRY_DISABLED=1&& next build",
    "start": "set NEXT_TELEMETRY_DISABLED=1&& next start -p 3000",
    "stop": "node scripts/kill-dev.js",
    "reset": "node scripts/reset-build.js",
    "clean": "node scripts/reset-build.js",
    "fresh": "set NEXT_PUBLIC_AUTO_SCAN=1&& node scripts/kill-dev.js && node scripts/reset-build.js && npm run dev",
    "lint": "next lint"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.11.6",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^11.0.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
